# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key

# JWT signing secret (min 32 characters)
JWT_SECRET=change-me-to-a-256-bit-secret-key-for-production-use

# PostgreSQL (Supabase)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=your_supabase_db_password

# Comma-separated frontend origins (add your Vercel URL after deploy)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload directory (use /app/uploads/contracts on Render with a persistent disk)
APP_UPLOAD_DIR=uploads/contracts
